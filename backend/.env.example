# ─────────────────────────────────────────────────────────────────
#  NexTalk — .env  (copy to .env and fill in your values)
# ─────────────────────────────────────────────────────────────────

# ── MongoDB ───────────────────────────────────────────────────────
# Local:
# MONGO_URI=mongodb://localhost:27017/nextalk
# Atlas (free tier → cloud.mongodb.com):
MONGO_URI=mongodb+srv://USERNAME:PASSWORD@cluster.mongodb.net/nextalk

# ── JWT ───────────────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_string_in_production_abc123xyz
JWT_EXPIRES_IN=7d

# ── Server ────────────────────────────────────────────────────────
PORT=5000

# ── CORS: comma-separated list of allowed frontend origins ────────
# For production, set your Vercel URL:
# FRONTEND_URL=https://your-app.vercel.app
# For local dev:
FRONTEND_URL=*
